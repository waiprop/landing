---
interface Props {
	eyebrow: string;
	title: string;
	subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
const hasCta = Astro.slots.has('default');
---

<section class="page-hero">
	<p class="eyebrow">{eyebrow}</p>
	<h1>{title}</h1>
	{subtitle && <p class="subtitle">{subtitle}</p>}
	{hasCta && (
		<div class="cta">
			<slot />
		</div>
	)}
</section>

<style>
	.page-hero {
		width: min(var(--container), 100%);
		margin-inline: auto;
		padding: clamp(56px, 8vw, 104px) 20px 0;
	}

	.eyebrow {
		max-width: 820px;
		margin: 0 0 12px;
		color: var(--color-brand);
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		max-width: 820px;
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.04;
	}

	.subtitle {
		max-width: 640px;
		margin: 18px 0 0;
		color: var(--color-muted);
		line-height: 1.65;
	}

	.cta {
		margin-top: 28px;
	}
</style>
