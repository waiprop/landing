---
import BrandIcon from '../ui/BrandIcon.astro';

const miniWeekDays = ['lu', 'ma', 'mi', 'ju', 'vi', 'sá', 'do'];
const miniDays = [
	...Array.from({ length: 30 }, (_, index) => ({ day: index + 1, muted: false })),
	...Array.from({ length: 5 }, (_, index) => ({ day: index + 1, muted: true })),
];

const weekDays = [
	{ name: 'lun', day: 22, today: true },
	{ name: 'mar', day: 23 },
	{ name: 'mié', day: 24 },
	{ name: 'jue', day: 25 },
	{ name: 'vie', day: 26 },
	{ name: 'sáb', day: 27 },
	{ name: 'dom', day: 28 },
];

const hours = ['08:00', '09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00'];

const events = [
	{ day: 0, start: 1, span: 1, title: 'Visita · Casa Yerba Buena', time: '09:00 – 10:00' },
	{ day: 0, start: 2, span: 1, title: 'Reunión · Familia Pérez', time: '10:00 – 11:00' },
	{ day: 0, start: 3, span: 1, title: 'Tasación · Depto. Centro', time: '11:00 – 12:00' },
	{ day: 0, start: 6, span: 2, title: 'Visita · Terreno Tafí Viejo', time: '14:00 – 16:00' },
	{ day: 1, start: 1, span: 1, title: 'Visita · Casa Barrio Norte', time: '09:00 – 10:00' },
	{ day: 1, start: 2, span: 1, title: 'Reunión · Sofía Vega', time: '10:00 – 11:00' },
	{ day: 1, start: 3, span: 1, title: 'Visita · Local comercial', time: '11:00 – 12:00' },
	{ day: 1, start: 6, span: 1, title: 'Tasación · PH Norte', time: '14:00 – 15:00' },
	{ day: 1, start: 7, span: 1, title: 'Visita · Depto. Francia', time: '15:00 – 16:00' },
	{ day: 2, start: 1, span: 1, title: 'Visita · Depto. Centro', time: '09:00 – 10:00' },
	{ day: 2, start: 2, span: 1, title: 'Reunión · Elena Ruiz', time: '10:00 – 11:00' },
	{ day: 2, start: 3, span: 1, title: 'Visita · Casa Las Talitas', time: '11:00 – 12:00' },
	{ day: 2, start: 4, span: 1, title: 'Tasación · Oficina', time: '12:00 – 13:00' },
	{ day: 2, start: 7, span: 1, title: 'Visita · Casa El Corte', time: '15:00 – 16:00' },
	{ day: 3, start: 1, span: 1, title: 'Visita · Casa Yerba Buena', time: '09:00 – 10:00' },
	{ day: 4, start: 6, span: 1, title: 'Reunión · Inversiones Sur', time: '14:00 – 15:00' },
];

const mobileEvents = [
	{ time: '09:00', title: 'Visita · Casa en Yerba Buena', meta: 'Familia Pérez · Lucía R.' },
	{ time: '11:00', title: 'Tasación · Departamento Centro', meta: 'Martín Díaz · Sofía M.', google: true },
	{ time: '13:00', title: 'Visita · Terreno Tafí Viejo', meta: 'Carlos Ruiz · Diego A.' },
	{ time: '16:30', title: 'Reunión · Familia González', meta: 'Familia González · Lucía R.' },
];
---

<div class="calendar-demo" aria-hidden="true">
	<div class="calendar-desktop">
		<aside class="calendar-side">
			<header class="mini-header">
				<span class="chevron">
					<svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"></path></svg>
				</span>
				<strong>junio 2026</strong>
				<span class="chevron">
					<svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"></path></svg>
				</span>
			</header>

			<div class="mini-calendar">
				{miniWeekDays.map((day) => <span class="mini-weekday">{day}</span>)}
				{miniDays.map(({ day, muted }) => (
					<span class:list={['mini-day', { 'is-today': !muted && day === 22, 'is-event': !muted && [18, 19, 23, 24, 25].includes(day), 'is-muted': muted }]}>{day}</span>
				))}
			</div>

			<div class="side-divider"></div>
			<h4>Resumen de hoy</h4>
			<dl class="summary-list">
				<div><dt>Total visitas</dt><dd>6</dd></div>
				<div><dt>Programadas</dt><dd class="is-blue">6</dd></div>
				<div><dt>Completadas</dt><dd class="is-green">0</dd></div>
				<div><dt>Canceladas</dt><dd class="is-muted">0</dd></div>
			</dl>

			<div class="side-divider side-divider--connection"></div>
			<div class="calendar-connection">
				<BrandIcon brand="google-calendar" size={28} decorative />
				<span><strong>Google Calendar</strong><small>Sincronizado</small></span>
				<span class="connection-action">Administrar</span>
			</div>
		</aside>

		<section class="calendar-main">
			<header class="calendar-toolbar">
				<div class="toolbar-navigation">
					<span class="toolbar-button">Hoy</span>
					<span class="toolbar-arrow">
						<svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"></path></svg>
					</span>
					<span class="toolbar-arrow">
						<svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"></path></svg>
					</span>
					<strong>22 Jun – 28 Jun 2026</strong>
				</div>
				<div class="toolbar-filters">
					<span>Todos los agentes <svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"></path></svg></span>
					<span>08:00 <svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"></path></svg></span>
					<i>–</i>
					<span>20:00 <svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"></path></svg></span>
				</div>
				<div class="view-selector"><span>Día</span><span class="is-active">Semana</span><span>Mes</span></div>
			</header>

			<div class="week-header">
				<span></span>
				{weekDays.map((day) => (
					<div class:list={['week-day', { 'is-today': day.today }]}>
						<span>{day.name}</span>
						<strong>{day.day}</strong>
					</div>
				))}
			</div>

			<div class="schedule-grid">
				<div class="time-column">
					{hours.map((hour) => <span>{hour}</span>)}
				</div>
				{weekDays.map((day, dayIndex) => (
					<div class:list={['schedule-day', { 'is-today': day.today }]}>
						{hours.map(() => <span class="schedule-cell"></span>)}
						{events.filter((event) => event.day === dayIndex).map((event) => (
							<article class="schedule-event" style={`--event-start:${event.start};--event-span:${event.span};`}>
								<strong>{event.title}</strong>
								<span>{event.time}</span>
								<small>Google Calendar</small>
							</article>
						))}
					</div>
				))}
			</div>
		</section>
	</div>

	<div class="calendar-mobile">
		<header class="mobile-header">
			<div><h4>Agenda de visitas</h4><p>Lunes 22 de junio</p></div>
			<span>Semana <svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"></path></svg></span>
		</header>

		<div class="mobile-days">
			{weekDays.slice(0, 5).map((day) => (
				<span class:list={['mobile-day', { 'is-today': day.today }]}><small>{day.name}</small><strong>{day.day}</strong></span>
			))}
		</div>

		<div class="mobile-events">
			{mobileEvents.map((event) => (
				<article class:list={['mobile-event', { 'is-google': event.google }]}>
					<time>{event.time}</time>
					<div><strong>{event.title}</strong><span>{event.meta}</span>{event.google && <small>Sincronizado con Google</small>}</div>
				</article>
			))}
		</div>

		<div class="mobile-connection">
			<BrandIcon brand="google-calendar" size={24} decorative />
			<span><strong>Google Calendar</strong><small>Sincronizado</small></span>
			<b>Administrar</b>
		</div>
	</div>
</div>

<style>
	.calendar-demo {
		--calendar-blue: #4285f4;
		--calendar-bg: #f4f5fa;
		--calendar-line: #e2e5ec;
		width: 100%;
		min-width: 0;
		color: #252833;
		font-family: Inter, ui-sans-serif, system-ui, sans-serif;
		text-align: left;
	}

	.calendar-demo svg {
		display: block;
		width: 1em;
		height: 1em;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.calendar-desktop {
		display: grid;
		grid-template-columns: clamp(220px, 20vw, 264px) minmax(0, 1fr);
		gap: clamp(14px, 2vw, 24px);
		width: 100%;
		max-width: 1320px;
		margin-inline: auto;
		padding: clamp(10px, 1.4vw, 18px);
		border-radius: 18px;
		background: var(--calendar-bg);
	}

	.calendar-side,
	.calendar-main {
		border: 1px solid #dde1e8;
		border-radius: 11px;
		background: #fff;
		box-shadow: 0 2px 8px rgba(31, 41, 55, 0.08);
	}

	.calendar-side {
		display: flex;
		flex-direction: column;
		padding: clamp(18px, 2.3vw, 30px) clamp(14px, 1.8vw, 24px);
	}

	.mini-header {
		display: grid;
		grid-template-columns: 26px 1fr 26px;
		align-items: center;
		margin-bottom: 22px;
	}

	.mini-header strong {
		font-size: 0.96rem;
		text-align: center;
	}

	.chevron {
		display: grid;
		place-items: center;
		color: #343945;
	}

	.chevron svg {
		width: 17px;
		height: 17px;
	}

	.mini-calendar {
		display: grid;
		grid-template-columns: repeat(7, 1fr);
		gap: 6px 2px;
		text-align: center;
	}

	.mini-weekday,
	.mini-day {
		display: grid;
		place-items: center;
		min-height: 27px;
		font-size: 0.74rem;
	}

	.mini-weekday {
		color: #8e939f;
	}

	.mini-day {
		position: relative;
		color: #30343d;
	}

	.mini-day.is-event::after {
		content: '';
		position: absolute;
		right: 24%;
		bottom: 2px;
		left: 24%;
		height: 1px;
		background: currentColor;
	}

	.mini-day.is-today {
		min-height: 34px;
		border-radius: 1px;
		background: var(--color-brand);
		color: #fff;
		font-weight: 800;
	}

	.mini-day.is-muted {
		color: #b7bbc4;
	}

	.side-divider {
		height: 1px;
		margin: clamp(20px, 2.8vw, 30px) 0 20px;
		background: var(--calendar-line);
	}

	.side-divider--connection {
		margin-top: auto;
	}

	.calendar-side h4 {
		margin: 0 0 13px;
		font-size: 0.92rem;
	}

	.summary-list {
		display: grid;
		gap: 11px;
		margin: 0;
	}

	.summary-list div {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.summary-list dt,
	.summary-list dd {
		margin: 0;
		font-size: 0.82rem;
	}

	.summary-list dt {
		color: #9297a2;
	}

	.summary-list dd {
		font-weight: 700;
	}

	.summary-list .is-blue { color: #376cf6; }
	.summary-list .is-green { color: #0ead49; }
	.summary-list .is-muted { color: #687c9a; }

	.calendar-connection {
		display: grid;
		grid-template-columns: 30px minmax(0, 1fr);
		align-items: center;
		gap: 9px;
	}

	.calendar-connection > span:nth-child(2),
	.mobile-connection > span {
		display: flex;
		flex-direction: column;
	}

	.calendar-connection strong,
	.mobile-connection strong {
		font-size: 0.8rem;
	}

	.calendar-connection small,
	.mobile-connection small {
		color: #10a74b;
		font-size: 0.72rem;
	}

	.connection-action {
		grid-column: 1 / -1;
		padding: 8px 10px;
		border: 1px solid #dfe3e9;
		border-radius: 8px;
		color: #4c5260;
		font-size: 0.74rem;
		font-weight: 700;
		text-align: center;
	}

	.calendar-main {
		min-width: 0;
		overflow: hidden;
		padding: clamp(14px, 1.6vw, 22px) clamp(12px, 1.6vw, 20px) 0;
	}

	.calendar-toolbar {
		display: flex;
		align-items: center;
		gap: 12px;
		min-width: 0;
		margin-bottom: 15px;
	}

	.toolbar-navigation,
	.toolbar-filters,
	.view-selector {
		display: flex;
		align-items: center;
	}

	.toolbar-navigation {
		gap: 8px;
		min-width: 0;
	}

	.toolbar-navigation > strong {
		font-size: clamp(0.84rem, 1.3vw, 1.08rem);
		white-space: nowrap;
	}

	.toolbar-button,
	.toolbar-filters > span,
	.view-selector {
		border: 1px solid #dfe2e8;
		border-radius: 8px;
		background: #fff;
		box-shadow: 0 1px 2px rgba(31, 41, 55, 0.06);
	}

	.toolbar-button {
		padding: 8px 11px;
		font-size: 0.78rem;
	}

	.toolbar-arrow {
		color: #353945;
	}

	.toolbar-arrow svg {
		width: 17px;
		height: 17px;
	}

	.toolbar-filters {
		gap: 6px;
		margin-left: auto;
	}

	.toolbar-filters > span {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 8px 10px;
		font-size: 0.75rem;
		white-space: nowrap;
	}

	.toolbar-filters svg {
		width: 13px;
		height: 13px;
		color: #a6abb4;
	}

	.toolbar-filters i {
		color: #999eaa;
		font-style: normal;
	}

	.view-selector {
		overflow: hidden;
		margin-left: auto;
		box-shadow: none;
	}

	.view-selector span {
		padding: 8px 11px;
		font-size: 0.76rem;
		font-weight: 600;
	}

	.view-selector span + span {
		border-left: 1px solid #dfe2e8;
	}

	.view-selector .is-active {
		background: #f0f1f6;
	}

	.week-header,
	.schedule-grid {
		display: grid;
		grid-template-columns: 46px repeat(7, minmax(66px, 1fr));
	}

	.week-header {
		border-bottom: 1px solid var(--calendar-line);
	}

	.week-day {
		padding: 8px 2px 12px;
		border-left: 1px solid var(--calendar-line);
		text-align: center;
	}

	.week-day span,
	.week-day strong {
		display: block;
	}

	.week-day span {
		color: #9095a0;
		font-size: 0.7rem;
	}

	.week-day strong {
		margin-top: 2px;
		font-size: 1rem;
	}

	.week-day.is-today {
		background: rgba(37, 154, 114, 0.06);
		color: var(--color-brand);
	}

	.schedule-grid {
		--row-height: clamp(42px, 6vh, 61px);
		position: relative;
	}

	.time-column {
		display: grid;
		grid-template-rows: repeat(8, var(--row-height));
	}

	.time-column span {
		padding: 6px 6px 0 0;
		color: #9297a2;
		font-size: 0.67rem;
		text-align: right;
		transform: translateY(-12px);
	}

	.schedule-day {
		position: relative;
		display: grid;
		grid-template-rows: repeat(8, var(--row-height));
		border-left: 1px solid var(--calendar-line);
	}

	.schedule-day.is-today {
		background: rgba(37, 154, 114, 0.045);
	}

	.schedule-cell {
		border-bottom: 1px solid var(--calendar-line);
	}

	.schedule-event {
		position: absolute;
		top: calc(var(--event-start) * var(--row-height) + 2px);
		right: 3px;
		left: 3px;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: 2px;
		height: calc(var(--event-span) * var(--row-height) - 4px);
		min-height: 40px;
		padding: 6px 7px;
		overflow: hidden;
		border-radius: 8px;
		background: var(--calendar-blue);
		color: #fff;
		box-shadow: 0 2px 5px rgba(35, 83, 182, 0.2);
	}

	.schedule-event strong,
	.schedule-event span,
	.schedule-event small {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.schedule-event strong {
		font-size: clamp(0.62rem, 0.78vw, 0.74rem);
	}

	.schedule-event span,
	.schedule-event small {
		font-size: clamp(0.56rem, 0.68vw, 0.66rem);
	}

	.schedule-event small {
		opacity: 0.86;
	}

	.calendar-mobile {
		display: none;
	}

	@media (max-width: 1120px) {
		.toolbar-filters {
			display: none;
		}
	}

	@media (max-width: 900px) {
		.calendar-desktop {
			grid-template-columns: 210px minmax(0, 1fr);
		}

		.view-selector span {
			padding-inline: 8px;
		}
	}

	@media (max-width: 760px) {
		.calendar-desktop {
			display: none;
		}

		.calendar-mobile {
			display: block;
		width: 100%;
		max-width: 440px;
		margin-inline: auto;
		padding: 18px 16px;
		border: 1px solid #dde1e8;
		border-radius: 16px;
		background: #fff;
		box-shadow: 0 16px 40px rgba(31, 41, 55, 0.1);
	}

	.mobile-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 16px;
	}

	.mobile-header h4,
	.mobile-header p {
		margin: 0;
	}

	.mobile-header h4 {
		font-size: 1rem;
	}

	.mobile-header p {
		margin-top: 3px;
		color: #8e939f;
		font-size: 0.76rem;
	}

	.mobile-header > span {
		display: flex;
		align-items: center;
		gap: 5px;
		padding: 7px 9px;
		border: 1px solid #dfe2e8;
		border-radius: 9px;
		font-size: 0.74rem;
		font-weight: 700;
	}

	.mobile-header svg {
		width: 13px;
		height: 13px;
	}

	.mobile-days {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 6px;
		margin-bottom: 17px;
	}

	.mobile-day {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		padding: 7px 0;
		border: 1px solid #dfe2e8;
		border-radius: 10px;
	}

	.mobile-day small {
		color: #8e939f;
		font-size: 0.64rem;
	}

	.mobile-day strong {
		font-size: 0.9rem;
	}

	.mobile-day.is-today {
		border-color: var(--color-brand);
		background: var(--color-brand);
		color: #fff;
	}

	.mobile-day.is-today small {
		color: rgba(255, 255, 255, 0.82);
	}

	.mobile-events {
		display: grid;
		gap: 9px;
	}

	.mobile-event {
		display: grid;
		grid-template-columns: 48px minmax(0, 1fr);
		gap: 10px;
		padding: 11px;
		border: 1px solid #e1e4ea;
		border-left: 4px solid var(--color-brand);
		border-radius: 11px;
		background: #fff;
	}

	.mobile-event.is-google {
		border-left-color: var(--calendar-blue);
	}

	.mobile-event time {
		color: #30343d;
		font-size: 0.76rem;
		font-weight: 800;
	}

	.mobile-event > div {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.mobile-event strong,
	.mobile-event span {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.mobile-event strong {
		font-size: 0.8rem;
	}

	.mobile-event span {
		margin-top: 2px;
		color: #8e939f;
		font-size: 0.69rem;
	}

	.mobile-event small {
		margin-top: 4px;
		color: var(--calendar-blue);
		font-size: 0.65rem;
	}

	.mobile-connection {
		display: grid;
		grid-template-columns: 26px minmax(0, 1fr) auto;
		align-items: center;
		gap: 9px;
		margin-top: 14px;
		padding: 11px;
		border-radius: 11px;
		background: #f1f8f5;
	}

	.mobile-connection b {
		padding: 7px 8px;
		border: 1px solid #dfe2e8;
		border-radius: 8px;
		background: #fff;
		color: #4c5260;
		font-size: 0.68rem;
	}

	@media (max-width: 390px) {
		.calendar-mobile {
			padding-inline: 12px;
		}

		.mobile-connection b {
			display: none;
		}
	}
</style>
