---

<svg class="mock-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[name] ?? icons.info}></svg>

<style>
	.mock-icon {
		display: block;
		width: 1em;
		height: 1em;
		overflow: visible;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.mock-icon :global(*) {
		fill: none;
		stroke: currentColor;
		vector-effect: non-scaling-stroke;
	}
</style>
