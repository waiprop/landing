---
import { Image } from 'astro:assets';
import logo from '../assets/logo_waichatt.svg';
import { site } from '../config/site';
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<a class="footer-logo" href={site.links.home} aria-label={`${site.name} inicio`}>
				<Image src={logo} alt={site.name} width={132} height={40} />
			</a>
			<p>WhatsApp, IA y CRM para inmobiliarias y desarrolladoras.</p>
		</div>
		<nav aria-label="Footer producto">
			<h2>Producto</h2>
			<a href="/#funciones">Funciones</a>
			<a href={site.links.pricing}>Precios</a>
			<a href={site.links.app} data-preserve-utm="true">Ingresar</a>
		</nav>
		<nav aria-label="Footer recursos">
			<h2>Recursos</h2>
			<a href={site.links.blog}>Blog</a>
			<a href={site.links.realEstate}>Para inmobiliarias</a>
			<a href={site.links.developers}>Para desarrolladoras</a>
		</nav>
		<nav aria-label="Footer legales">
			<h2>Legales</h2>
			<a href={site.links.terms}>Términos y Condiciones</a>
			<a href={site.links.privacy}>Política de Privacidad</a>
		</nav>
		<div class="footer-contact">
			<h2>Contacto</h2>
			<a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
			<a href={site.contact.whatsapp}>{site.contact.phone}</a>
		</div>
	</div>
	<div class="footer-bottom">
		<p class="footer-note">
			Somos proveedores de tecnología en la Plataforma de WhatsApp Business de Meta. Waichatt es un producto independiente; WhatsApp y Meta son marcas de Meta Platforms, Inc.
		</p>
		<p class="footer-copyright">© 2026 Waichatt. Todos los derechos reservados.</p>
	</div>
</footer>

<style>
	.site-footer {
		padding: 64px 20px 30px;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		background: #14201b;
	}

	.footer-inner {
		display: grid;
		grid-template-columns: minmax(220px, 1.3fr) repeat(4, minmax(150px, 1fr));
		gap: 28px;
		width: min(var(--container), 100%);
		margin-inline: auto;
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
	}

	.footer-logo img {
		width: 132px;
		max-width: 132px;
		height: auto;
		filter: brightness(0) invert(1);
	}

	.footer-brand p,
	.footer-note,
	.footer-copyright {
		color: rgba(255, 255, 255, 0.68);
		line-height: 1.6;
	}

	.footer-brand p {
		max-width: 28ch;
		margin: 12px 0 0;
	}

	h2 {
		margin: 0 0 12px;
		color: #ffffff;
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	nav,
	.footer-contact {
		display: grid;
		align-content: start;
		gap: 9px;
	}

	a {
		color: rgba(255, 255, 255, 0.68);
		font-weight: 700;
		transition:
			color 180ms ease,
			opacity 180ms ease;
	}

	a:hover,
	a:focus-visible {
		color: #ffffff;
	}

	.footer-note {
		margin: 0;
		max-width: 92ch;
		font-size: 0.92rem;
	}

	.footer-bottom {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 12px 32px;
		width: min(var(--container), 100%);
		margin: 34px auto 0;
		padding-top: 20px;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-note {
		flex: 1 1 480px;
	}

	.footer-copyright {
		margin: 0;
		flex: 0 0 auto;
		color: rgba(255, 255, 255, 0.78);
		font-size: 0.86rem;
		font-weight: 600;
		white-space: nowrap;
	}

	@media (max-width: 900px) {
		.footer-inner {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.footer-inner {
			grid-template-columns: 1fr;
		}

	}
</style>
