---
import { Image } from 'astro:assets';
import heroImage from '../../assets/hero.png';
import { plans } from '../../config/plans';
import { site } from '../../config/site';
import BrandIcon from '../ui/BrandIcon.astro';
import Button from '../ui/Button.astro';

const comparison = [
	{
		before: 'Mensajes de madrugada que quedan para la mañana',
		afterLead: 'La IA responde ',
		afterStrong: 'al instante, 24/7',
	},
	{
		before: 'Interesados que se enfrían sin seguimiento',
		afterLead: 'CRM con pipeline y ',
		afterStrong: 'recordatorios automáticos',
	},
	{
		before: 'El WhatsApp repartido entre los celulares del equipo',
		afterLead: 'Bandeja compartida con ',
		afterStrong: 'asignación por vendedor',
	},
	{
		before: 'Sin saber cuántas consultas entran ni se cierran',
		afterLead: 'Métricas ',
		afterStrong: 'reales de consultas y ventas',
	},
	{
		before: 'Respuestas lentas que el cliente ya no espera',
		afterLead: 'Respondé y agendá visitas ',
		afterStrong: 'desde un solo lugar',
	},
];

const modules = [
	{
		title: 'Conversaciones',
		kicker: 'Todo tu WhatsApp en una sola bandeja.',
		text: 'Cada consulta entra a un inbox compartido con etiquetas, asignación por vendedor y el historial completo del cliente al lado del chat.',
	},
	{
		title: 'Agente IA',
		kicker: 'Respuesta inmediata, a cualquier hora.',
		text: 'La IA entiende qué busca el cliente, recomienda propiedades reales de tu cartera y registra los datos en el CRM.',
	},
	{
		title: 'CRM',
		kicker: 'Cada consulta se vuelve una oportunidad medible.',
		text: 'Contactos, leads y pipeline conectados a las conversaciones para saber qué vendedor atiende y en qué etapa está cada interesado.',
	},
	{
		title: 'Propiedades',
		kicker: 'Tu cartera, lista para vender en todos lados.',
		text: 'Cargá o importá desde Tokko y dejá tus propiedades disponibles para la IA, el CRM, tu web y tus conversaciones.',
	},
	{
		title: 'Calendario',
		kicker: 'De la consulta a la visita, sin idas y vueltas.',
		text: 'Agendá visitas vinculadas a lead, propiedad y vendedor, sincronizadas con Google Calendar.',
	},
	{
		title: 'Vista general',
		kicker: 'Números reales de tu operación.',
		text: 'Consultas, respuestas de IA, rendimiento comercial y demanda por propiedad en un tablero fácil de leer.',
	},
];

const faqs = [
	['¿Waichatt es un CRM o solo un bot de WhatsApp?', 'Es una plataforma CRM completa: conversaciones por WhatsApp, gestión de leads, propiedades, visitas, equipo, reportes y un agente IA configurable.'],
	['¿La IA puede recomendar propiedades?', 'Sí. Interpreta zona, presupuesto, tipo de operación y preferencias para sugerir propiedades de tu cartera.'],
	['¿Puedo apagar la IA en una conversación?', 'Sí. Cada chat puede tener el agente activado o pausado, para que tu equipo tome el control cuando quiera.'],
	['¿Sirve para ventas y alquileres?', 'Sí. Gestionás propiedades en venta, alquiler o temporal, y seguís cada oportunidad desde el primer contacto hasta la negociación.'],
	['¿Se puede importar desde Tokko Broker?', 'Sí. Importación y sincronización de propiedades vía API.'],
	['¿Incluye una web para mi negocio?', 'Sí. Un sitio propio que se actualiza solo con tu cartera de propiedades.'],
	['¿Ofrecen prueba gratis?', 'Sí. Empezás gratis sin tarjeta, y el plan Pro tiene 7 días de prueba.'],
	['¿Hay costos ocultos?', 'No. El precio es claro desde el inicio. Incluye un límite mensual de uso de IA; si necesitás ampliar, se informa antes.'],
];
---

<section class="problem section-band" id="problema" aria-labelledby="problema-title">
	<div class="section-inner">
		<div class="section-head section-head--center">
			<p class="eyebrow">El problema y la solución</p>
			<h2 id="problema-title">De consultas que se pierden a <span class="accent">ventas organizadas</span></h2>
			<p>
				Tenés los interesados. Lo que falta es responder, ordenar y hacer seguimiento sin depender
				de quién mira el celular. Esto es lo que cambia con Waichatt.
			</p>
		</div>
		<div class="compare">
			<div class="compare-card compare-card--win">
				<h3 class="compare-title">Con Waichatt</h3>
				<ul>
					{comparison.map((row) => (
						<li>
							<span class="ico ico--check" aria-hidden="true">✓</span>
							<span>{row.afterLead}<strong>{row.afterStrong}</strong></span>
						</li>
					))}
				</ul>
			</div>
			<div class="compare-card compare-card--lose">
				<h3 class="compare-title">Sin Waichatt</h3>
				<ul>
					{comparison.map((row) => (
						<li>
							<span class="ico ico--x" aria-hidden="true">✕</span>
							<span>{row.before}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</div>
</section>

<section class="modules section-band" id="funciones" aria-labelledby="funciones-title">
	<div class="section-inner">
		<div class="section-head">
			<p class="eyebrow">Funciones</p>
			<h2 id="funciones-title">Todo lo que tu equipo necesita, en una sola plataforma</h2>
			<p>Conversaciones, IA, CRM, propiedades, calendario y métricas conectadas desde el primer lead.</p>
		</div>

		<div class="product-shot">
			<Image src={heroImage} alt="Bandeja de conversaciones de Waichatt con agente IA, etiquetas y ficha del cliente." widths={[720, 1080, 1350]} sizes="(max-width: 900px) 100vw, 1080px" loading="lazy" decoding="async" />
		</div>

		<div class="module-grid">
			{modules.map((module) => (
				<article class="module-card">
					<h3>{module.title}</h3>
					<strong>{module.kicker}</strong>
					<p>{module.text}</p>
				</article>
			))}
		</div>
	</div>
</section>

<section class="audiences section-band" id="para-quien" aria-labelledby="audiences-title">
	<div class="section-inner">
		<div class="section-head">
			<p class="eyebrow">Para quién es</p>
			<h2 id="audiences-title">Pensado para cómo trabajás vos</h2>
		</div>
		<div class="audience-grid">
			<article>
				<h3>Para inmobiliarias</h3>
				<p>Centralizá las consultas de toda tu cartera, organizá a tus vendedores y no dejes ningún interesado sin seguimiento.</p>
				<a href={site.links.realEstate}>Ver enfoque para inmobiliarias</a>
			</article>
			<article>
				<h3>Para desarrolladoras</h3>
				<p>Cuando lanzás un emprendimiento, la IA responde al instante, califica interesados y los reparte entre tu equipo comercial.</p>
				<a href={site.links.developers}>Ver enfoque para desarrolladoras</a>
			</article>
		</div>
	</div>
</section>

<section class="steps section-band" id="como-funciona" aria-labelledby="steps-title">
	<div class="section-inner">
		<div class="section-head">
			<p class="eyebrow">Cómo funciona</p>
			<h2 id="steps-title">Empezá a vender mejor en el día</h2>
		</div>
		<ol class="step-list">
			<li><span>1</span><strong>Creá tu cuenta</strong><p>Gratis, sin tarjeta y lista para empezar a configurar tu negocio.</p></li>
			<li><span>2</span><strong>Conectá tu WhatsApp y cargá tus propiedades</strong><p>O importalas desde Tokko en minutos.</p></li>
			<li><span>3</span><strong>Activá tu agente IA</strong><p>Mirá cómo cada consulta se convierte en un lead organizado.</p></li>
		</ol>
		<Button href={site.links.register} track="How it works register">Empezá gratis</Button>
	</div>
</section>

<section class="proof section-band" aria-labelledby="proof-title">
	<div class="section-inner">
		<div class="section-head">
			<p class="eyebrow">Prueba social</p>
			<h2 id="proof-title">Una plataforma que trabaja mientras vos dormís</h2>
		</div>
		<div class="metric-grid">
			<article><strong>24/7</strong><span>la IA responde también fuera de horario.</span></article>
			<article><strong>Segundos</strong><span>para contestar una consulta nueva.</span></article>
			<article><strong>1 lugar</strong><span>para consultas, propiedades y visitas.</span></article>
			<article><strong>Tokko</strong><span>para importar tu cartera sin cargar todo a mano.</span></article>
		</div>
		<div class="integration-strip" aria-label="Integraciones principales">
			<span><BrandIcon brand="whatsapp" size="22" aria-label="WhatsApp" /> WhatsApp</span>
			<span><BrandIcon brand="meta" size="22" aria-label="Meta" /> Meta</span>
			<span><BrandIcon brand="google-calendar" size="22" aria-label="Google Calendar" /> Google Calendar</span>
			<span>Tokko Broker</span>
			<span>MercadoLibre</span>
		</div>
	</div>
</section>

<section class="pricing section-band" id="precios" aria-labelledby="pricing-title">
	<div class="section-inner">
		<div class="section-head">
			<p class="eyebrow">Precios</p>
			<h2 id="pricing-title">Planes claros, sin sorpresas</h2>
			<p>Empezá gratis y pasá al Pro cuando lo necesites. Sin costos ocultos.</p>
		</div>
		<div class="pricing-grid">
			{plans.map((plan) => (
				<article class:list={['price-card', plan.featured && 'price-card--featured']}>
					{plan.featured && <span class="popular">Más elegido</span>}
					<h3>{plan.name}</h3>
					<p class="price"><strong>{plan.priceLabel}</strong><span>/mes</span></p>
					<p class="plan-detail">{plan.detail}</p>
					<ul>
						{plan.features.map((feature) => <li>{feature}</li>)}
					</ul>
					<Button href={site.links.register} variant={plan.featured ? 'primary' : 'ghost'} track={plan.track}>{plan.cta}</Button>
				</article>
			))}
		</div>
		<p class="pricing-note">Todos los planes incluyen un límite mensual de uso de IA. Si necesitás ampliar, te lo informamos antes.</p>
	</div>
</section>

<section class="closing section-band" aria-labelledby="closing-title">
	<div class="section-inner narrow">
		<h2 id="closing-title">La próxima consulta puede ser una venta. O un mensaje más sin responder.</h2>
		<p>Probá Waichatt gratis y descubrí cuántas oportunidades estabas dejando pasar.</p>
		<Button href={site.links.register} track="Final register">Empezá gratis</Button>
		<small>Sin tarjeta. Empezás en minutos.</small>
	</div>
</section>

<section class="faq section-band" id="faq" aria-labelledby="faq-title">
	<div class="section-inner">
		<div class="section-head">
			<p class="eyebrow">FAQ</p>
			<h2 id="faq-title">Preguntas frecuentes</h2>
		</div>
		<div class="faq-list">
			{faqs.map(([question, answer]) => (
				<details>
					<summary>{question}</summary>
					<p>{answer}</p>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.section-band {
		padding: clamp(72px, 9vw, 128px) 20px;
	}

	.section-band:nth-of-type(even) {
		background: #f6f7f6;
	}

	.problem.section-band {
		background: linear-gradient(180deg, #f5f7fb, #eceff5);
	}

	.modules.section-band {
		background: #f6f7f6;
	}

	.section-inner {
		width: min(var(--container), 100%);
		margin-inline: auto;
	}

	.narrow {
		max-width: 820px;
	}

	.section-head {
		max-width: 760px;
		margin-bottom: 34px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: var(--color-brand);
		font-size: 0.82rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0;
	}

	h2 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 4vw, 3.25rem);
		line-height: 1.08;
	}

	h3 {
		margin: 0;
		color: var(--color-text);
		font-size: 1.2rem;
	}

	p {
		color: var(--color-muted);
		line-height: 1.68;
	}

	.section-head--center {
		max-width: 720px;
		margin-inline: auto;
		margin-bottom: clamp(36px, 5vw, 60px);
		text-align: center;
	}

	.accent {
		color: var(--color-brand);
	}

	.compare {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		width: min(940px, 100%);
		margin-inline: auto;
	}

	.compare-card {
		border-radius: var(--radius-lg);
	}

	.compare-title {
		margin: 0;
		padding-bottom: 18px;
		border-bottom: 1px solid rgba(20, 32, 27, 0.08);
		text-align: center;
		font-size: clamp(1.3rem, 2.2vw, 1.6rem);
		font-weight: 800;
	}

	/* Tarjeta ganadora: blanca, elevada y montada sobre la otra */
	.compare-card--win {
		position: relative;
		z-index: 2;
		margin-right: -32px;
		padding: clamp(28px, 3.2vw, 42px) clamp(24px, 2.8vw, 36px);
		border: 1px solid #eef1ef;
		background: var(--color-surface);
		box-shadow: 0 34px 80px rgba(20, 32, 27, 0.16);
	}

	.compare-card--win .compare-title {
		color: var(--color-text);
	}

	/* Tarjeta perdedora: plana, hundida detrás */
	.compare-card--lose {
		position: relative;
		z-index: 1;
		padding: clamp(34px, 3.8vw, 52px) clamp(24px, 2.8vw, 36px);
		padding-left: calc(clamp(24px, 2.8vw, 36px) + 44px);
		border: 1px solid rgba(20, 32, 27, 0.07);
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.5);
	}

	.compare-card--lose .compare-title {
		color: var(--color-muted);
		font-weight: 700;
	}

	.compare ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.compare li {
		display: flex;
		gap: 12px;
		align-items: center;
		padding: 16px 0;
		border-bottom: 1px solid rgba(20, 32, 27, 0.07);
		line-height: 1.45;
	}

	.compare li:last-child {
		border-bottom: 0;
		padding-bottom: 0;
	}

	.compare-card--win li {
		color: var(--color-text);
	}

	.compare-card--win strong {
		font-weight: 800;
	}

	.compare-card--lose li {
		color: var(--color-muted);
	}

	.ico {
		flex: 0 0 auto;
		width: 18px;
		font-size: 1.05rem;
		font-weight: 900;
		line-height: 1;
		text-align: center;
	}

	.ico--check {
		color: #1fae5a;
	}

	.ico--x {
		color: #e5484d;
	}

	.product-shot {
		overflow: hidden;
		margin-bottom: 28px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		box-shadow: 0 22px 60px rgba(20, 32, 27, 0.1);
	}

	.product-shot :global(img) {
		width: 100%;
		height: auto;
	}

	.module-grid,
	.audience-grid,
	.metric-grid,
	.pricing-grid {
		display: grid;
		gap: 16px;
	}

	.module-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.module-card,
	.audience-grid article,
	.metric-grid article,
	.price-card,
	.faq-list details {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-surface);
	}

	.module-card {
		padding: 24px;
	}

	.module-card strong {
		display: block;
		margin-top: 12px;
		color: var(--color-brand-strong);
	}

	.audience-grid,
	.pricing-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.audience-grid article {
		padding: clamp(24px, 3vw, 34px);
	}

	.audience-grid a {
		color: var(--color-brand);
		font-weight: 800;
	}

	.step-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		margin: 0 0 28px;
		padding: 0;
		list-style: none;
	}

	.step-list li {
		padding: 24px;
		border-left: 3px solid var(--color-brand);
		background: var(--color-surface);
	}

	.step-list span,
	.metric-grid strong {
		color: var(--color-brand);
		font-weight: 900;
	}

	.step-list span {
		display: inline-grid;
		place-items: center;
		width: 34px;
		height: 34px;
		margin-bottom: 16px;
		border-radius: 50%;
		background: var(--color-brand-soft);
	}

	.step-list strong {
		display: block;
		color: var(--color-text);
		font-size: 1.1rem;
	}

	.metric-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.metric-grid article {
		padding: 22px;
	}

	.metric-grid strong {
		display: block;
		margin-bottom: 8px;
		font-size: clamp(1.55rem, 3vw, 2.25rem);
		line-height: 1;
	}

	.metric-grid span {
		color: var(--color-muted);
		line-height: 1.5;
	}

	.integration-strip {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 24px;
	}

	.integration-strip span {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-height: 40px;
		padding: 0 13px;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-surface);
		color: var(--color-text);
		font-weight: 800;
	}

	.pricing-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		align-items: stretch;
	}

	.price-card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 26px;
	}

	.price-card--featured {
		border-color: #b8e0d2;
		box-shadow: 0 22px 60px rgba(37, 154, 114, 0.12);
	}

	.popular {
		align-self: flex-start;
		margin-bottom: 14px;
		padding: 5px 10px;
		border-radius: 999px;
		background: var(--color-brand-soft);
		color: var(--color-brand-strong);
		font-size: 0.78rem;
		font-weight: 900;
	}

	.price {
		margin: 20px 0 4px;
	}

	.price strong {
		color: var(--color-text);
		font-size: 2.2rem;
		line-height: 1;
	}

	.price span,
	.plan-detail,
	.pricing-note {
		color: var(--color-muted);
	}

	.price-card ul {
		display: grid;
		gap: 10px;
		margin: 24px 0;
		padding: 0;
		list-style: none;
	}

	.price-card li {
		color: var(--color-text);
		line-height: 1.45;
	}

	.price-card li::before {
		content: '✓';
		margin-right: 8px;
		color: var(--color-brand);
		font-weight: 900;
	}

	.price-card :global(.button) {
		margin-top: auto;
	}

	.pricing-note {
		margin-top: 20px;
	}

	.closing {
		text-align: center;
	}

	.closing p {
		max-width: 620px;
		margin: 20px auto 28px;
	}

	.closing small {
		display: block;
		margin-top: 14px;
		color: var(--color-muted);
	}

	.faq-list {
		display: grid;
		gap: 10px;
		max-width: 960px;
	}

	.faq-list details {
		padding: 18px 20px;
	}

	.faq-list summary {
		color: var(--color-text);
		font-weight: 900;
		cursor: pointer;
	}

	.faq-list p {
		margin-bottom: 0;
	}

	@media (max-width: 980px) {
		.module-grid,
		.metric-grid,
		.pricing-grid,
		.step-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 760px) {
		.compare {
			grid-template-columns: 1fr;
			gap: 18px;
			width: min(460px, 100%);
		}

		.compare-card--win {
			margin-right: 0;
		}

		.compare-card--lose {
			padding: clamp(24px, 5vw, 32px);
		}
	}

	@media (max-width: 680px) {
		.section-band {
			padding: 64px 16px;
		}

		.module-grid,
		.audience-grid,
		.metric-grid,
		.pricing-grid,
		.step-list {
			grid-template-columns: 1fr;
		}
	}
</style>
