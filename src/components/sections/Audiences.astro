---
import { site } from '../../config/site';
---

<section class="audiences section-band" id="para-quien" aria-labelledby="audiences-title">
	<div class="section-inner audiences-layout">
		<div class="section-head audiences-head">
			<p class="eyebrow">Para quién es</p>
			<h2 id="audiences-title">Un enfoque para cada operación</h2>
			<p>Elegí el recorrido que mejor representa cómo trabaja tu equipo comercial.</p>
		</div>

		<div class="audience-list">
			<a class="audience-row" href={site.links.realEstate} aria-label="Ver enfoque para inmobiliarias">
				<span class="audience-copy">
					<span class="audience-kicker">Cartera activa</span>
					<strong>Para inmobiliarias</strong>
					<span>Centralizá consultas, ordená vendedores y seguí cada interesado sin perder conversaciones.</span>
				</span>
				<span class="audience-cta">
					Ver enfoque
				</span>
			</a>

			<a class="audience-row" href={site.links.developers} aria-label="Ver enfoque para desarrolladoras">
				<span class="audience-copy">
					<span class="audience-kicker">Lanzamientos</span>
					<strong>Para desarrolladoras</strong>
					<span>Respondé al instante, calificá interesados y distribuí oportunidades durante campañas.</span>
				</span>
				<span class="audience-cta">
					Ver enfoque
				</span>
			</a>
		</div>
	</div>
</section>

<style>
	.audiences {
		background: var(--color-surface);
	}

	.audiences-layout {
		display: grid;
		grid-template-columns: minmax(260px, 0.72fr) minmax(0, 1.28fr);
		gap: clamp(34px, 6vw, 88px);
		align-items: start;
	}

	.audiences-head {
		margin-bottom: 0;
	}

	.audiences-head p:not(.eyebrow) {
		margin: 18px 0 0;
		max-width: 46ch;
		font-size: 1.08rem;
	}

	.audience-list {
		display: grid;
		gap: 12px;
	}

	.audience-row {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: clamp(18px, 3vw, 34px);
		align-items: start;
		padding: clamp(22px, 2.5vw, 30px);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-surface);
		box-shadow: 0 1px 2px rgba(20, 32, 27, 0.03);
		transition:
			transform 220ms ease,
			border-color 200ms ease,
			box-shadow 220ms ease,
			color 200ms ease;
	}

	.audience-row:hover,
	.audience-row:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(37, 154, 114, 0.38);
		box-shadow:
			0 1px 2px rgba(20, 32, 27, 0.04),
			0 18px 42px rgba(20, 32, 27, 0.08);
	}

	.audience-copy {
		display: grid;
		gap: 10px;
		min-width: 0;
	}

	.audience-kicker {
		margin-bottom: 10px;
		color: var(--color-brand);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.audience-copy strong {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(1.45rem, 2vw, 1.85rem);
		line-height: 1.14;
	}

	.audience-copy span:last-child {
		max-width: 58ch;
		color: var(--color-muted);
		font-size: 1.02rem;
		line-height: 1.65;
	}

	.audience-cta {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		color: var(--color-brand);
		font-weight: 800;
		white-space: nowrap;
		text-decoration: underline;
		text-decoration-color: rgba(37, 154, 114, 0.28);
		text-decoration-thickness: 2px;
		text-underline-offset: 5px;
		transition:
			color 200ms ease,
			text-decoration-color 200ms ease;
	}

	.audience-row:hover .audience-cta,
	.audience-row:focus-visible .audience-cta {
		color: var(--color-brand-hover);
		text-decoration-color: currentColor;
	}

	@media (max-width: 900px) {
		.audiences-layout {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.audience-row {
			grid-template-columns: 1fr;
			gap: 12px;
		}

		.audience-cta {
			margin-top: 4px;
		}
	}
</style>
