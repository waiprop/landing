---
import { plans } from '../../config/plans';
import PlanCard from '../PlanCard.astro';

const plan = plans[0];
---

<section class="pricing section-band" id="precios" aria-labelledby="pricing-title">
	<div class="section-inner pricing-layout">
		<div class="pricing-intro">
			<p class="eyebrow">Precios</p>
			<h2 id="pricing-title">Un plan simple, sin sorpresas</h2>
			<p>Todo incluido en un solo plan. Probalo 5 días gratis, sin tarjeta.</p>
			<p class="pricing-note">El plan incluye un límite mensual de uso de IA. Si necesitás ampliar, te lo informamos antes.</p>
		</div>
		<div class="pricing-card-col">
			<PlanCard plan={plan} track="Pricing pro" />
		</div>
	</div>
</section>

<style>
	.pricing-layout {
		display: grid;
		grid-template-columns: minmax(0, 480px) minmax(0, 410px);
		justify-content: center;
		align-items: center;
		gap: clamp(32px, 4vw, 64px);
	}

	.pricing-intro {
		max-width: 480px;
	}

	.pricing-intro h2 {
		margin-top: 12px;
	}

	.pricing-intro > p {
		margin: 18px 0 0;
		font-size: 1.08rem;
	}

	.pricing-note {
		margin-top: 22px;
		font-size: 0.95rem;
	}

	@media (max-width: 900px) {
		.pricing-layout {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 36px;
		}

		.pricing-intro {
			max-width: 560px;
			text-align: center;
		}

		.pricing-card-col {
			width: min(440px, 100%);
		}
	}
</style>
