---
import { site } from '../../config/site';
import Button from '../ui/Button.astro';

const steps = [
	{
		title: 'Creá tu cuenta',
		desc: 'Gratis, sin tarjeta y lista para empezar a configurar tu negocio.',
	},
	{
		title: 'Conectá tu WhatsApp y cargá tus propiedades',
		desc: 'O importalas desde Tokko en minutos.',
	},
	{
		title: 'Activá tu agente IA',
		desc: 'Mirá cómo cada consulta se convierte en un lead organizado.',
	},
];
---

<section class="steps section-band" id="como-funciona" aria-labelledby="steps-title">
	<div class="section-inner">
		<div class="section-head section-head--center">
			<p class="eyebrow">Cómo funciona</p>
			<h2 id="steps-title">Empezá a vender mejor en el día</h2>
			<p>Tres pasos simples para tener tu agente atendiendo y ordenando tus leads.</p>
		</div>

		<ol class="stepper">
			{steps.map((step, i) => (
				<li class="step">
					<span class="step-node">{i + 1}</span>
					<div class="step-body">
						<strong>{step.title}</strong>
						<p>{step.desc}</p>
					</div>
				</li>
			))}
		</ol>

		<div class="steps-cta">
			<Button href={site.links.register} track="How it works register">Empezá gratis</Button>
		</div>
	</div>
</section>

<style>
	.stepper {
		--node: 56px;
		--gap: clamp(20px, 3vw, 48px);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--gap);
		margin: clamp(40px, 5vw, 64px) auto clamp(36px, 4vw, 48px);
		padding: 0;
		list-style: none;
	}

	.step {
		position: relative;
		padding-top: calc(var(--node) + 24px);
		text-align: center;
	}

	/* Círculo numerado, apoyado sobre la línea de progreso */
	.step-node {
		position: absolute;
		top: 0;
		left: 50%;
		z-index: 1;
		display: grid;
		place-items: center;
		width: var(--node);
		height: var(--node);
		transform: translateX(-50%);
		border-radius: 50%;
		background: linear-gradient(135deg, var(--color-brand), var(--color-brand-hover));
		color: #fff;
		font-size: 1.35rem;
		font-weight: 800;
		box-shadow:
			0 0 0 6px var(--color-brand-soft),
			0 10px 22px rgba(37, 154, 114, 0.28);
	}

	/* Línea continua de centro a centro entre nodos */
	.step:not(:last-child)::before {
		content: '';
		position: absolute;
		top: calc(var(--node) / 2);
		left: 50%;
		z-index: 0;
		width: calc(100% + var(--gap));
		height: 3px;
		transform: translateY(-50%);
		background: rgba(37, 154, 114, 0.28);
	}

	.step-body strong {
		display: block;
		margin-bottom: 8px;
		color: var(--color-text);
		font-size: 1.2rem;
		line-height: 1.25;
	}

	.step-body p {
		margin: 0 auto;
		max-width: 32ch;
		font-size: 0.98rem;
	}

	.steps-cta {
		display: flex;
		justify-content: center;
	}

	/* Stepper vertical en pantallas chicas */
	@media (max-width: 720px) {
		.stepper {
			grid-template-columns: 1fr;
			gap: 0;
			max-width: 460px;
		}

		.step {
			display: grid;
			grid-template-columns: var(--node) 1fr;
			gap: 18px;
			padding-top: 0;
			padding-bottom: clamp(24px, 6vw, 32px);
			text-align: left;
		}

		.step:last-child {
			padding-bottom: 0;
		}

		.step-node {
			position: static;
			transform: none;
		}

		/* La línea pasa a ser vertical entre nodos */
		.step:not(:last-child)::before {
			top: var(--node);
			left: calc(var(--node) / 2);
			width: 3px;
			height: calc(100% - var(--node));
			transform: translateX(-50%);
		}

		.step-body {
			padding-top: 8px;
		}

		.step-body p {
			margin: 0;
			max-width: none;
		}
	}
</style>
