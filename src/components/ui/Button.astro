---
interface Props {
	href: string;
	variant?: 'primary' | 'ghost';
	size?: 'sm' | 'md';
	class?: string;
	ariaLabel?: string;
	track?: string;
	preserveUtm?: boolean;
}

const {
	href,
	variant = 'primary',
	size = 'md',
	class: className,
	ariaLabel,
	track,
	preserveUtm = href.includes('waichatt.app'),
	...attrs
} = Astro.props;
---

<a
	href={href}
	aria-label={ariaLabel}
	data-track={track}
	data-preserve-utm={preserveUtm ? 'true' : undefined}
	class:list={['button', `button-${variant}`, `button-${size}`, className]}
	{...attrs}
>
	<slot />
</a>

<style>
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid transparent;
		border-radius: var(--radius-md);
		font-weight: 800;
		white-space: nowrap;
		/*
			El relleno (fill in) lo anima el inset box-shadow.
			Mantenemos la misma cantidad de sombras en reposo y en hover
			(drop shadow + inset) para que la animación sea fluida.
		*/
		transition:
			border-color 200ms ease,
			color 200ms ease,
			box-shadow 280ms ease,
			transform 200ms ease;
	}

	.button:hover,
	.button:focus-visible {
		transform: translateY(-2px);
	}

	.button:active {
		transform: translateY(0);
	}

	.button-primary {
		border-color: var(--color-brand);
		background: var(--color-brand);
		color: #ffffff;
		box-shadow:
			0 10px 22px rgba(37, 154, 114, 0.18),
			inset 0 0 0 0 var(--color-brand-hover);
	}

	.button-primary:hover,
	.button-primary:focus-visible {
		border-color: var(--color-brand-hover);
		box-shadow:
			0 16px 34px rgba(37, 154, 114, 0.28),
			inset 0 -3.5em 0 0 var(--color-brand-hover);
	}

	.button-ghost {
		border-color: var(--color-border);
		background: var(--color-surface);
		color: var(--color-text);
		box-shadow:
			0 1px 2px rgba(20, 32, 27, 0.04),
			inset 0 0 0 0 var(--color-brand-soft);
	}

	.button-ghost:hover,
	.button-ghost:focus-visible {
		border-color: #b8e0d2;
		color: var(--color-brand-strong);
		box-shadow:
			0 12px 26px rgba(20, 32, 27, 0.1),
			inset 0 -3.5em 0 0 var(--color-brand-soft);
	}

	.button-sm {
		min-height: 44px;
		padding: 0 18px;
		font-size: 0.95rem;
	}

	.button-md {
		min-height: 50px;
		padding: 0 24px;
		font-size: 1rem;
	}
</style>
