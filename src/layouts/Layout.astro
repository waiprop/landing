---
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogImage?: string;
	canonical?: string;
	noindex?: boolean;
}

const { title, description, ogTitle, ogDescription, ogImage, canonical, noindex } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<SEO
			title={title}
			description={description}
			ogTitle={ogTitle}
			ogDescription={ogDescription}
			ogImage={ogImage}
			canonical={canonical}
			noindex={noindex}
		/>
	</head>
	<body>
		<Header />
		<slot />
	</body>
</html>
