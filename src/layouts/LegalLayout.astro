---
import Layout from './Layout.astro';

interface Props {
	title: string;
	description: string;
	canonical: string;
	heading: string;
	lastUpdated: string;
}

const { title, description, canonical, heading, lastUpdated } = Astro.props;
---

<Layout title={title} description={description} canonical={canonical}>
	<main class="legal-page">
		<article>
			<h1>{heading}</h1>
			<p class="lead">Última actualización: {lastUpdated}.</p>
			<slot />
		</article>
	</main>
</Layout>

<style>
	.legal-page {
		padding: clamp(56px, 8vw, 104px) 20px;
	}

	article {
		width: min(820px, 100%);
		margin-inline: auto;
	}

	h1 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.05;
	}

	.lead {
		color: var(--color-brand);
		font-weight: 900;
	}

	/* El contenido llega vía <slot>, así que necesita estilos globales. */
	article :global(h2) {
		margin-top: 34px;
		color: var(--color-text);
	}

	article :global(section) {
		margin-top: 36px;
	}

	article :global(section:first-of-type) {
		margin-top: 0;
	}

	article :global(p) {
		color: var(--color-muted);
		line-height: 1.72;
	}

	article :global(ul) {
		margin: 14px 0 0;
		padding-left: 1.3rem;
		color: var(--color-muted);
		line-height: 1.72;
	}

	article :global(li + li) {
		margin-top: 8px;
	}

	article :global(strong) {
		color: var(--color-text);
	}

	article :global(a) {
		color: var(--color-brand);
		font-weight: 900;
	}

	article :global(.legal-meta) {
		margin-top: 48px;
		padding-top: 22px;
		border-top: 1px solid var(--color-border);
	}

	article :global(.legal-return) {
		margin-top: 34px;
		text-align: center;
	}
</style>
