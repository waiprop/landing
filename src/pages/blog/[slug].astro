---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { blogPostingSchema, breadcrumbSchema, faqSchema, howToSchema } from '../../config/schema';
import { site, type Author } from '../../config/site';
import Faq from '../../components/sections/Faq.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postPath = `/blog/${post.id}/`;
const publishedTime = post.data.publishDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.publishDate).toISOString();
const author: Author = post.data.author ?? site.defaultAuthor;
const authorInitials = author.name
	.split(' ')
	.slice(0, 2)
	.map((part) => part[0])
	.join('');
const jsonLd = [
	blogPostingSchema(post, postPath),
	breadcrumbSchema([
		{ name: 'Inicio', path: '/' },
		{ name: 'Blog', path: '/blog/' },
		{ name: post.data.title, path: postPath },
	]),
	...(post.data.howTo ? [howToSchema(post.data.howTo)] : []),
	...(post.data.faqs?.length ? [faqSchema(post.data.faqs)] : []),
];
---

<Layout
	title={`${post.data.title} - Waichatt`}
	description={post.data.description}
	canonical={postPath}
	ogType="article"
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	jsonLd={jsonLd}
>
	<main class="article-page">
		<article>
			<a class="back" href="/blog/">Blog</a>
			<h1>{post.data.title}</h1>
			<p class="description">{post.data.description}</p>
			<p class="meta">
				<span class="author">{author.url ? <a href={author.url}>{author.name}</a> : author.name}</span>
				{author.role && <span class="role"> · {author.role}</span>}
				<time datetime={post.data.publishDate.toISOString()}>{post.data.publishDate.toLocaleDateString('es-ES')}</time>
			</p>
			<div class="content">
				<Content />
			</div>
			<footer class="author-card">
				<span class="author-avatar" aria-hidden="true">{authorInitials}</span>
				<div class="author-info">
					<strong class="author-name">
						{author.url ? <a href={author.url} target="_blank" rel="noopener">{author.name}</a> : author.name}
					</strong>
					{author.role && <span class="author-role">{author.role}</span>}
					{author.bio && <p class="author-bio">{author.bio}</p>}
				</div>
			</footer>
		</article>
	</main>
	{post.data.faqs?.length && (
		<Faq
			items={post.data.faqs}
			title="Preguntas frecuentes"
			lead="Respuestas rápidas sobre el tema de este artículo."
		/>
	)}
</Layout>

<style>
	.article-page {
		padding: clamp(56px, 8vw, 104px) 20px;
	}

	article {
		width: min(760px, 100%);
		margin-inline: auto;
	}

	.back,
	time {
		color: var(--color-brand);
		font-weight: 900;
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 6px 10px;
		margin: 16px 0 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.meta .author {
		color: var(--color-text);
		font-weight: 700;
	}

	.meta .author a {
		color: inherit;
	}

	h1 {
		margin: 18px 0;
		color: var(--color-text);
		font-size: clamp(2.2rem, 5vw, 3.8rem);
		line-height: 1.05;
	}

	.description,
	.content :global(p) {
		color: var(--color-muted);
		line-height: 1.72;
	}

	.description {
		font-size: 1.16rem;
	}

	.content {
		margin-top: 40px;
	}

	.content :global(p) {
		font-size: 1.06rem;
	}

	.author-card {
		display: flex;
		align-items: flex-start;
		gap: 16px;
		margin-top: clamp(40px, 6vw, 64px);
		padding: 22px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
	}

	.author-avatar {
		flex: none;
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--color-brand), var(--color-brand-hover));
		color: #fff;
		font-weight: 800;
	}

	.author-info {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.author-name {
		color: var(--color-text);
		font-size: 1.05rem;
	}

	.author-name a {
		color: inherit;
	}

	.author-role {
		color: var(--color-brand);
		font-weight: 700;
		font-size: 0.92rem;
	}

	.author-bio {
		margin: 6px 0 0;
		color: var(--color-muted);
		line-height: 1.6;
		font-size: 0.98rem;
	}
</style>
