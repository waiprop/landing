---
import Layout from '../layouts/Layout.astro';
import { plans } from '../config/plans';
import PlanCard from '../components/PlanCard.astro';

const plan = plans[0];
---

<Layout title="Precios de Waichatt - Un plan simple para inmobiliarias" description="El plan de Waichatt con todo incluido: agente IA, CRM y propiedades ilimitadas. Probalo 5 días gratis, sin tarjeta." canonical="/precios">
	<main class="pricing-page">
		<div class="pricing-layout">
			<div class="pricing-intro">
				<p class="eyebrow">Precios</p>
				<h1>Un plan simple, sin sorpresas</h1>
				<p class="subtitle">Todo incluido en un solo plan. Probalo 5 días gratis, sin tarjeta.</p>
				<p class="note">El plan incluye un límite mensual de uso de IA. Si necesitás ampliar, te lo informamos antes.</p>
			</div>
			<div class="pricing-card-col">
				<PlanCard plan={plan} track="Pricing page Plan Pro" />
			</div>
		</div>
	</main>
</Layout>

<style>
	.pricing-page {
		width: min(var(--container), 100%);
		margin-inline: auto;
		padding: clamp(56px, 8vw, 104px) 20px;
	}

	.pricing-layout {
		display: grid;
		grid-template-columns: minmax(0, 480px) minmax(0, 410px);
		justify-content: center;
		align-items: center;
		gap: clamp(32px, 4vw, 64px);
	}

	.pricing-intro {
		max-width: 480px;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: var(--color-brand);
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.04;
	}

	.subtitle {
		margin: 18px 0 0;
		color: var(--color-muted);
		font-size: 1.08rem;
		line-height: 1.65;
	}

	.note {
		margin: 22px 0 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	@media (max-width: 900px) {
		.pricing-layout {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 36px;
		}

		.pricing-intro {
			max-width: 560px;
			text-align: center;
		}

		.pricing-card-col {
			width: min(440px, 100%);
		}
	}
</style>
