---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
import { plans } from '../config/plans';
import Button from '../components/ui/Button.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Precios de Waichatt - Un plan simple para inmobiliarias" description="El plan de Waichatt con todo incluido: agente IA, CRM y propiedades ilimitadas. Probalo 5 días gratis, sin tarjeta." canonical="/precios">
	<main>
		<PageHeader
			eyebrow="Precios"
			title="Un plan simple, sin sorpresas"
			subtitle="Todo incluido en un solo plan. Probalo 5 días gratis, sin tarjeta."
		/>
		<section class="plans" aria-label="Planes">
			{plans.map((plan) => (
				<article class:list={[plan.featured && 'featured']}>
					<h2>{plan.name}</h2>
					<strong>{plan.priceLabel}<small>/mes</small></strong>
					<p>{plan.summary}</p>
					<Button href={site.links.register} variant={plan.featured ? 'primary' : 'ghost'} track={`Pricing page ${plan.name}`}>{plan.cta}</Button>
				</article>
			))}
		</section>
	</main>
</Layout>

<style>
	.plans {
		display: grid;
		justify-content: center;
		grid-template-columns: min(460px, 100%);
		gap: 16px;
		width: min(var(--container), 100%);
		margin-inline: auto;
		padding: 48px 20px clamp(56px, 8vw, 104px);
	}

	article {
		display: flex;
		flex-direction: column;
		padding: 28px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-surface);
	}

	.featured {
		border-color: #b8e0d2;
		box-shadow: 0 22px 60px rgba(37, 154, 114, 0.12);
	}

	h2 {
		margin: 0;
		color: var(--color-text);
	}

	article strong {
		display: block;
		margin-top: 22px;
		color: var(--color-text);
		font-size: 2rem;
	}

	small {
		color: var(--color-muted);
		font-size: 1rem;
	}

	article p {
		color: var(--color-muted);
		line-height: 1.65;
	}

	article :global(.button) {
		margin-top: auto;
	}
</style>
