---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
import Button from '../components/ui/Button.astro';
import PageHeader from '../components/PageHeader.astro';
import BenefitGrid from '../components/sections/BenefitGrid.astro';
import Faq from '../components/sections/Faq.astro';
import { serviceSchema, breadcrumbSchema, faqSchema } from '../config/schema';
import { realEstateFaqs } from '../config/faqs';

const benefits = [
	{ title: 'Bandeja compartida', text: 'Todos los mensajes en un solo lugar, con historial y asignación por vendedor.' },
	{ title: 'Propiedades conectadas', text: 'La IA recomienda opciones de tu cartera según zona, presupuesto y operación.' },
	{ title: 'Seguimiento comercial', text: 'Cada consulta entra al pipeline para medir etapas, visitas y oportunidades.' },
];

const jsonLd = [
	serviceSchema({
		name: 'Waichatt para inmobiliarias',
		description:
			'Plataforma de CRM con agente de IA que centraliza las consultas de WhatsApp, las vincula con propiedades y organiza el seguimiento comercial de una inmobiliaria.',
		audienceType: 'Inmobiliarias',
		path: site.links.realEstate,
	}),
	faqSchema(realEstateFaqs),
	breadcrumbSchema([
		{ name: 'Inicio', path: '/' },
		{ name: 'Para inmobiliarias', path: site.links.realEstate },
	]),
];
---

<Layout title="Waichatt para inmobiliarias - WhatsApp, IA y CRM" description="Centraliza consultas, propiedades, visitas y seguimiento comercial en una sola plataforma para inmobiliarias." canonical="/para-inmobiliarias" jsonLd={jsonLd}>
	<main>
		<PageHeader
			eyebrow="Para inmobiliarias"
			title="Ordena tu WhatsApp y no pierdas ningún interesado"
			subtitle="Centraliza las consultas de toda tu cartera, organiza a tus vendedores y vincula cada conversación con propiedades reales."
		>
			<Button href={site.links.register} track="Real estate page register">Empieza gratis</Button>
		</PageHeader>
		<BenefitGrid items={benefits} label="Beneficios para inmobiliarias" />
		<Faq
			items={realEstateFaqs}
			title="Preguntas de inmobiliarias"
			lead="Dudas frecuentes sobre cómo Waichatt ordena las consultas, las propiedades y el equipo comercial."
		/>
	</main>
</Layout>
