---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Features from '../components/sections/Features.astro';
import Audiences from '../components/sections/Audiences.astro';
import Steps from '../components/sections/Steps.astro';
import Pricing from '../components/sections/Pricing.astro';
import Faq from '../components/sections/Faq.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import { organizationSchema, websiteSchema, softwareApplicationSchema, faqSchema, howToSchema } from '../config/schema';
import { steps } from '../config/steps';
---

<Layout
	ogTitle="Waichatt - Tu WhatsApp atiende solo"
	ogDescription="WhatsApp + IA + CRM en un solo lugar. Para inmobiliarias y desarrolladoras. Empieza gratis, sin tarjeta."
	canonical="/"
	jsonLd={[organizationSchema, websiteSchema, softwareApplicationSchema, faqSchema(), howToSchema({ name: 'Cómo empezar a vender con Waichatt', steps })]}
>
	<main>
		<Hero />
		<Features />
		<Audiences />
		<Steps />
		<Pricing />
		<Faq />
		<FinalCta />
	</main>
</Layout>
